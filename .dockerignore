# --- Version control ---
.git
.gitignore
.github

# --- Documentation & reports (not needed inside the image) ---
README.md
Security_report/
docs/

# --- Security test fixtures (intentionally vulnerable, never ship these) ---
security-fixtures/

# --- Tests ---
tests/
**/*.test.js
**/*.spec.js

# --- Infrastructure as Code (build context doesn't need Terraform) ---
infrastructure/
*.tf
*.tfvars
*.tfstate
*.tfstate.*
.terraform/

# --- Security scanner configs (used in CI, not at runtime) ---
.checkov.yml
.semgrepignore

# --- Docker-related (avoid recursive copy issues) ---
Dockerfile
docker-compose.yml
docker-compose.security.yml
docker-compose*.yml

# --- Nginx config (mounted separately, not baked into app image) ---
nginx/

# --- Node.js ---
node_modules/
npm-debug.log
yarn-error.log
.npm

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
env/

# --- Editor / OS junk ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Environment & secrets (NEVER bake secrets into an image) ---
.env
.env.*
*.pem
*.key
*.crt
secrets/

# --- Logs ---
*.log
logs/

# --- CI/CD leftovers ---
.checkov_report*
*.sarif
