# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file — it is (and should stay) in .gitignore.

# --- Application ---
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=changeme-generate-a-random-32-byte-value

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=changeme

# --- Email service (used by the "extra Feature of email" commit) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=changeme@example.com
SMTP_PASSWORD=changeme
EMAIL_FROM_ADDRESS=no-reply@example.com

# --- Elasticsearch / Kibana (security dashboard) ---
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
KIBANA_HOST=http://localhost:5601

# --- Alert service ---
ALERT_WEBHOOK_URL=https://hooks.example.com/your-webhook
ALERT_EMAIL_RECIPIENTS=security-team@example.com

# --- Terraform / Cloud provider (if provisioning real infra) ---
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme
AWS_REGION=us-east-1
TF_VAR_environment=dev
