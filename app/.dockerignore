# Files and directories to exclude from Docker build context
# This reduces build context size and prevents sensitive data leakage

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (NEVER include in image)
.env
.env.*
!.env.example

# Test files
tests/
coverage/
test-results/
*.test.js
*.spec.js
jest.config.js

# Development tools
.eslintrc*
.eslintignore
.prettierrc*
nodemon.json
.nodemonignore

# Version control
.git/
.gitignore
.gitattributes

# Documentation
*.md
docs/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# CI/CD
.github/
.gitlab-ci.yml
Jenkinsfile

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs
logs/
*.log

# Build artifacts
dist/
build/
