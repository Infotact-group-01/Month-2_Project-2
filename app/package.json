{
  "name": "ecommerce-devsecops-app",
  "version": "1.0.0",
  "description": "Sample e-commerce application for DevSecOps pipeline demonstration",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --runInBand --forceExit",
    "test:ci": "jest --coverage --ci --runInBand --forceExit --reporters=default --reporters=jest-junit",
    "lint": "eslint src tests --ext .js",
    "lint:fix": "eslint src tests --ext .js --fix",
    "audit:ci": "npm audit --audit-level=high"
  },
  "keywords": ["ecommerce", "devsecops", "security", "pipeline"],
  "author": "DevSecOps Intern",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.0.3",
    "express": "4.18.2",
    "express-rate-limit": "6.7.0",
    "express-validator": "7.0.1",
    "helmet": "7.0.0",
    "jsonwebtoken": "9.0.0",
    "morgan": "1.10.0",
    "uuid": "9.0.0",
    "winston": "3.8.2"
  },
  "devDependencies": {
    "eslint": "8.42.0",
    "jest": "29.5.0",
    "jest-junit": "16.0.0",
    "nodemon": "3.0.1",
    "supertest": "6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    },
    "reporters": [
      "default",
      ["jest-junit", {
        "outputDirectory": "test-results",
        "outputName": "junit.xml"
      }]
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
